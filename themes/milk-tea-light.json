    "problemsWarningIcon.foreground": "#C0913A",
    "problemsInfoIcon.foreground": "#5B7FA5",
    "editorMarkerNavigationError.background": "#A66B5C",
    "editorMarkerNavigationWarning.background": "#C0913A",
    "editorMarkerNavigationInfo.background": "#5B7FA5",
    "inputValidation.errorBackground": "#F5E5DE",
    "inputValidation.errorBorder": "#A66B5C",
    "inputValidation.errorForeground": "#6B2A18",

    "focusBorder": "#D9775780",
    "editorOverviewRuler.border": "#E0D4C2"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#A89880",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C0602A"
      }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": {
        "foreground": "#6A8D55"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#B8860B"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#5B7FA5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#8B6DA8"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#4A3D30"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "entity.name.tag.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7A6650"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#996040"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#C0602A"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#5B7FA5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#5B9A8B"
      }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#C0602A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#3D3029",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#3D3029",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#5B7FA5"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#7A6650"
      }
    },
    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#5B7FA5"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#8B6DA8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#C0602A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#8B7E6A"
      }
    }
  ]
}
